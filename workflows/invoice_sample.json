      "parameters": {
        "html": "<!DOCTYPE html><html lang=\"de\"><head><meta charset=\"UTF-8\">\n<style>\n* { margin:0; padding:0; box-sizing:border-box; }\nbody { font-family:Arial,Helvetica,sans-serif; font-size:10pt; color:#1a1a1a; }\n.page { width:210mm; padding:18mm 20mm 28mm 20mm; }\n.hdr  { display:flex; justify-content:space-between; align-items:flex-start;\n        padding-bottom:5mm; border-bottom:2px solid #1a1a1a; margin-bottom:8mm; }\n.logo img { max-height:44px; max-width:160px; }\n.co  { text-align:right; font-size:8pt; color:#555; line-height:1.65; }\n.co strong { display:block; font-size:10.5pt; color:#1a1a1a; margin-bottom:1mm; }\n.meta-row { display:flex; justify-content:space-between; margin-bottom:9mm; }\n.adr { font-size:9pt; line-height:1.75; }\n.adr-lbl { font-size:7pt; text-transform:uppercase; letter-spacing:1px; color:#aaa; margin-bottom:1.5mm; }\n.doc-title { font-size:22pt; font-weight:bold; color:#1a1a1a; margin-bottom:8mm; }\ntable.t { width:100%; border-collapse:collapse; margin-bottom:6mm; font-size:9pt; }\ntable.t thead tr { background:#f5f5f5; }\ntable.t th { padding:2.5mm 3.5mm; font-size:7.5pt; text-transform:uppercase; color:#777;\n             font-weight:bold; border-bottom:1.5px solid #ccc; text-align:left; }\ntable.t th.r, table.t td.r { text-align:right; }\ntable.t tbody tr { border-bottom:1px solid #f0f0f0; }\ntable.t td { padding:3mm 3.5mm; vertical-align:top; }\n.totals-wrap { display:flex; justify-content:flex-end; margin-bottom:8mm; }\n.totals { min-width:70mm; font-size:9pt; }\n.trow { display:flex; justify-content:space-between; padding:1.5mm 0; }\n.trow.sep { border-top:1px solid #ddd; margin-top:1.5mm; padding-top:2.5mm; }\n.trow.bold { font-weight:bold; font-size:11pt; border-top:2px solid #1a1a1a;\n             margin-top:2mm; padding-top:2.5mm; }\n.slbl { font-size:7.5pt; font-weight:bold; text-transform:uppercase; letter-spacing:0.5px;\n        color:#aaa; margin:6mm 0 2mm; }\n.pbox { background:#f8f8f8; border-left:3px solid #ddd; padding:4mm 5mm;\n        font-size:9pt; line-height:1.8; margin-bottom:6mm; }\n.clause { margin-bottom:5mm; }\n.ctitle { font-size:9.5pt; font-weight:bold; margin-bottom:2mm; }\np { font-size:9pt; line-height:1.65; color:#333; margin-bottom:3mm; }\n.sig-row { display:flex; gap:16mm; margin-top:14mm; }\n.sig { flex:1; padding-top:2mm; border-top:1px solid #bbb; font-size:8pt; color:#777; }\n.footer { position:fixed; bottom:10mm; left:20mm; right:20mm; border-top:1px solid #ddd;\n          padding-top:2.5mm; display:flex; justify-content:space-between;\n          font-size:6.5pt; color:#bbb; }</style></head><body><div class=\"page\">\n  <div class=\"hdr\">\n    <div class=\"logo\"><img src=\"https://storage.googleapis.com/dee-empire-artifacts/dee-empire.PNG\" alt=\"Dee Empire\"></div>\n    <div class=\"co\">\n      <strong>Dee Empire</strong>\n      Forststra&szlig;e 6 &middot; 96264 Altenkunstadt<br>\n      admin@dee-empire.com &middot; 09572 8744 123<br>\n      dee-empire.com\n    </div>\n  </div>\n  <div class=\"meta-row\">\n    <div class=\"adr\"><div class=\"adr-lbl\">Rechnungsempf&auml;nger</div><strong>Mustermann GmbH</strong><br>Max Mustermann<br>Musterstra&szlig;e 1<br>12345 Berlin<br>Deutschland</div>\n    <div class=\"adr\" style=\"text-align:right\">\n      <div class=\"adr-lbl\">Rechnungsdaten</div>\n      Rechnungsnr.: <strong>DEE-INV-2026-DEMO</strong><br>\n      Rechnungsdatum: 08.06.2026<br>\n      F&auml;lligkeitsdatum: <strong>08.07.2026</strong><br>\n      Leistungszeitraum: Juni 2026\n    </div>\n  </div>\n  <div class=\"doc-title\">Rechnung</div>\n  <table class=\"t\">\n    <thead><tr>\n      <th style=\"width:7%\">Pos.</th><th>Beschreibung</th>\n      <th class=\"r\" style=\"width:11%\">Menge</th>\n      <th class=\"r\" style=\"width:16%\">Einzelpreis</th>\n      <th class=\"r\" style=\"width:9%\">MwSt.</th>\n      <th class=\"r\" style=\"width:16%\">Betrag</th>\n    </tr></thead>\n    <tbody>\n      <tr><td>1</td><td>AI Automation Consulting</td><td class=\"r\">10 h</td>\n          <td class=\"r\">150,00 EUR</td><td class=\"r\">19 %</td><td class=\"r\">1.500,00 EUR</td></tr>\n      <tr><td>2</td><td>Workflow-Setup &amp; Training</td><td class=\"r\">1 Pauschal</td>\n          <td class=\"r\">500,00 EUR</td><td class=\"r\">19 %</td><td class=\"r\">500,00 EUR</td></tr>\n    </tbody>\n  </table>\n  <div class=\"totals-wrap\"><div class=\"totals\">\n    <div class=\"trow\"><span>Nettobetrag</span><span>2.000,00 EUR</span></div>\n    <div class=\"trow sep\"><span>MwSt. 19&nbsp;%</span><span>380,00 EUR</span></div>\n    <div class=\"trow bold\"><span>Gesamtbetrag</span><span>2.380,00 EUR</span></div>\n  </div></div>\n  <div class=\"slbl\">Zahlungsinformationen</div>\n  <div class=\"pbox\">\n    Bitte &uuml;berweisen Sie <strong>2.380,00 EUR</strong> bis zum <strong>08.07.2026</strong>\n    unter Angabe der Rechnungsnr. <strong>DEE-INV-2026-DEMO</strong>.<br>\n    <strong>Kontoinhaber:</strong> Dee Empire &nbsp;&bull;&nbsp;\n    <strong>IBAN:</strong> DE71&nbsp;7706&nbsp;1040&nbsp;0002&nbsp;3637&nbsp;3 &nbsp;&bull;&nbsp;\n    <strong>BIC:</strong> GENODEF1ALK\n  </div>\n  <div class=\"footer\">\n    <span>Dee Empire &middot; Forststra&szlig;e 6 &middot; 96264 Altenkunstadt</span>\n    <span>St.-Nr.: 230/274/01007 &middot; USt-IdNr.: DE455289768</span>\n    <span>IBAN: DE7177061040000236373 &middot; BIC: GENODEF1ALK</span>\n  </div></div></body></html>",
