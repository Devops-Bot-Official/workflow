{
  "nodes": [
    {
      "node_id": "node_start",
      "type": "start",
      "name": "Start: HTML Page Test",
      "description": "Manually start a safe test of the new html_page node.",
      "parameters": {},
      "position": { "x": 0, "y": 320 },
